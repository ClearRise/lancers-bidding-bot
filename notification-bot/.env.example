# Page to poll (マイページのダッシュボードや新着一覧など、ログイン後に見たいURL)
LANCERS_DASHBOARD_URL=https://www.lancers.jp/work/search

# Playwright storage state (recommended): run `npm run session:save` once after login
STORAGE_STATE_PATH=./storage-state.json

# Alternative: path to a JSON array of cookies (browser export). Ignored if storage state exists and loads.
# COOKIES_PATH=./cookies.json

# Poll interval (ms)
REFRESH_INTERVAL_MS=30000

# Optional filters (budget in JPY, empty = no limit)
MIN_BUDGET_JPY=
MAX_BUDGET_JPY=
# If true, tasks with no parsable budget are skipped when min/max are set (see filters.ts)
SKIP_IF_BUDGET_UNKNOWN=false

# Comma-separated: task must match at least one (title/description), unless empty = any
MATCH_KEYWORDS=

# Comma-separated: skip if title/description contains any
EXCLUDE_KEYWORDS=

# POST JSON to your bid bot when a new suitable task appears
BID_BOT_URL=http://127.0.0.1:3847/notify

# Optional shared secret header for the bid bot
# BID_BOT_SECRET=

# Headless browser (true in production)
HEADLESS=true

# Windows/macOS/Linux toast when a matching task is found (node-notifier)
DESKTOP_NOTIFICATION=true

# Windows: SnoreToast shows "SnoreToast" until you register an app id once: npm run toast:register
# Must match the id used by that command (default below).
# WINDOWS_TOAST_APP_ID=Lancers.NotificationBot
# Optional: override icon path (default: src/download.jpg next to the built app)
# NOTIFICATION_ICON_PATH=

# First run: only save current work ids, do not notify (recommended)
BOOTSTRAP_SILENT=true

# Persist known ids so restarts do not re-fire
SEEN_IDS_PATH=./seen-work-ids.json
