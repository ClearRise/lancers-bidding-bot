# Page to poll (マイページのダッシュボードや新着一覧など、ログイン後に見たいURL)
LANCERS_DASHBOARD_URL=https://www.lancers.jp/work/search
# Optional: monitor multiple URLs at the same time (comma-separated).
# If set, this takes priority over LANCERS_DASHBOARD_URL.
# LANCERS_DASHBOARD_URLS=https://www.lancers.jp/work/search?type[]=project,https://www.lancers.jp/work/search?open=1

# Playwright storage state (recommended): run `npm run session:save` once after login
STORAGE_STATE_PATH=./storage-state.json

# Alternative: path to a JSON array of cookies (browser export). Ignored if storage state exists and loads.
# COOKIES_PATH=./cookies.json

# Poll interval (ms)
REFRESH_INTERVAL_MS=30000

# Filter settings moved to filter_settings/settings.json:
# - minBudgetJpy
# - maxBudgetJpy
# - skipIfBudgetUnknown

# Keyword filtering is file-based:
# - include list: filter_settings/include_keywords
# - exclude list: filter_settings/exclude_keywords
# (one keyword per line, checked against task snippet)
# AI filtering prompt: filter_settings/ai_prompt.txt
# AI filtering options (enabled/model/maxSnippetChars): filter_settings/settings.json

# POST JSON to your bid bot when a new suitable task appears
BID_BOT_URL=http://127.0.0.1:3847/notify

# Optional shared secret header for the bid bot
# BID_BOT_SECRET=

# Headless browser (true in production)
HEADLESS=true

# Windows/macOS/Linux toast when a matching task is found (node-notifier)
DESKTOP_NOTIFICATION=true

# Windows: SnoreToast shows "SnoreToast" until you register an app id once: npm run toast:register
# Must match the id used by that command (default below).
# WINDOWS_TOAST_APP_ID=Lancers.NotificationBot
# Toast body image (large icon in notification content)
# Optional: override toast image path (default: assets/icons/lancers-badge.jpg)
NOTIFICATION_ICON_PATH=./assets/icons/lancers-badge.jpg
# Toast app/header icon (small icon near app name in Windows toast header).
# Applied when running: npm run toast:register
NOTIFICATION_APP_ICON_PATH=./assets/icons/lancers-knight.jpg

# First run: only save current work ids, do not notify (recommended)
BOOTSTRAP_SILENT=true

# Persist known ids so restarts do not re-fire
SEEN_IDS_PATH=./seen-work-ids.json

# OpenAI API key
# OPENAI_API_KEY=

# Inference API key https://www.hpc-ai.com/
INFERENCE_API_KEY=
INFERENCE_BASE_URL=https://api.hpc-ai.com/inference/v1
INFERENCE_MODEL=minimax/minimax-m2.5

# DeepSeek API key
# DEEPSEEK_API_KEY=
# Optional DeepSeek model (default: deepseek-chat)
# DEEPSEEK_MODEL=deepseek-chat

