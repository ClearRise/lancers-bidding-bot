LANCERS_DASHBOARD_URL=https://www.lancers.jp/work/search
STORAGE_STATE_PATH=./storage-state.json
HEADLESS=true
POLL_INTERVAL_MS=60000
SEEN_IDS_PATH=./bid-history.json
BID_QUEUE_PATH=./bid-queue.json

# Bid strategy
MAX_BIDS_PER_CYCLE=2
MIN_BUDGET_JPY=
MAX_BUDGET_JPY=

# Bid content
DEFAULT_PROPOSAL_TEXT=はじめまして。要件に沿って丁寧に対応いたします。詳細を伺えれば最適な進め方をご提案します。
DEFAULT_BID_AMOUNT_JPY=

# Optional safety switches
DRY_RUN=true

# API server for notification-bot -> bid-bot handoff
BID_BOT_PORT=3847
# BID_BOT_SECRET=

# Optional: run browser monitor in same process
ENABLE_MONITOR=false
