LANCERS_DASHBOARD_URL=https://www.lancers.jp/work/search
STORAGE_STATE_PATH=./storage-state.json
HEADLESS=true
POLL_INTERVAL_MS=60000
SEEN_IDS_PATH=./bid-history.json
BID_QUEUE_PATH=./bid-queue.json

# Queue consumer strategy
MAX_BIDS_PER_CYCLE=2
MIN_BUDGET_JPY=
MAX_BUDGET_JPY=

# AI configuration
ENABLE_AI_PROPOSAL=false
BID_PROPOSAL_MODE=template
# proposal templates for template mode:
# - filter_settings/proposal_templates/template-1.txt (dashboard index 0)
# - filter_settings/proposal_templates/template-2.txt (dashboard index 1)
# - ...
BUDGET_DEFINITION_RATE=0.5
INFERENCE_API_KEY=
INFERENCE_BASE_URL=https://api.hpc-ai.com/inference/v1
INFERENCE_MODEL=minimax/minimax-m2.5

BASE44_BASE_URL=https://app.base44.com/api/agents/BASE44_CONVERSATION_ID
BASE44_CONVERSATION_ID=
BASE44_API_KEY=


GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1/responses
# Optional: GROQ_MODEL=openai/gpt-oss-20b
MISTRAL_API_KEY=
# Optional: MISTRAL_MODEL=mistral-small-latest

# Optional safety switches
DRY_RUN=true
JAPANESE_STUDY_EVERY_N_PROPERTIES=50

# API server for notification-bot -> bid-bot handoff
BID_BOT_PORT=3847
BID_BOT_SECRET=

# Desktop toast on bid result (submitted / failed)
DESKTOP_NOTIFICATION=true
# Optional App User Model ID for Windows toast header app name
WINDOWS_TOAST_APP_ID=Cursor
# Optional icon path used during toast registration
WINDOWS_TOAST_ICON_PATH=./cursor-ai-code-icon.ico

# Run queue consumer loop in same process (opens queued links and bids)
ENABLE_MONITOR=true